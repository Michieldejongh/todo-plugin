#!/usr/bin/env bash
CWD=$(pwd)
CWD_SLUG=$(echo "$CWD" | tr '/' '-')
SESSION=$(ls -t ~/.claude/projects/${CWD_SLUG}/*.jsonl 2>/dev/null | head -1 | xargs -I{} basename {} .jsonl 2>/dev/null)
BRANCH=$(git branch --show-current 2>/dev/null || echo "")

if [[ -z "$SESSION" ]]; then
  echo "Geen sessie gevonden voor $CWD" >&2
  exit 1
fi

# Geef extra args (zoals --force, --plan x) door aan het script
exec node ${CLAUDE_PLUGIN_ROOT}/scripts/todo.js \
  session-update --session "$SESSION" --branch "$BRANCH" --cwd "$CWD" "$@"
